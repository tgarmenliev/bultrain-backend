# Copy to .env and fill in. The real .env lives only on the server and in your
# password manager — it is never committed.

# Port the Express server listens on (nginx proxies to it). Defaults to 3000.
PORT=3000

# Client API keys, checked by middleware/verifyMobileClient.js.
# The mobile keys additionally require a "BulTrainMobile" User-Agent; the
# screen key does not, because the E-ink device cannot set one.
IOS_API_KEY=
ANDROID_API_KEY=
SCREEN_API_KEY=

# Admin panel: password for POST /api/admin/login, secret for signing the
# admin_token JWT cookie.
ADMIN_PASSWORD=
JWT_SECRET=

# Origin allowed through CORS for the admin UI, e.g. https://api.bultrain.eu
ADMIN_ORIGIN=

# ── Feature flags ───────────────────────────────────────────────────────────
# Each one gates a background job. They exist so code can be deployed and
# checked on the server before it starts doing work.
SCHEDULE_SOURCE=gtfs   # gtfs | legacy — where schedule lookups read from
REALTIME=on            # GTFS-Realtime poller
RT_HISTORY=on          # quiet delay-history accumulation (needs REALTIME=on)
LIVE_ACTIVITY=off      # ActivityKit push worker (needs REALTIME=on for data)

# ── APNs / Live Activity ────────────────────────────────────────────────────
# Credentials for the ActivityKit pushes. Registration works without them; only
# the push worker needs them, and it logs and stays idle if they are missing.
#
# APNS_KEY_P8 takes either the PEM contents or a path to the .p8 file. Prefer
# a path on the server (chmod 600, outside the repo). If you paste the contents
# into .env, keep it on one line with literal \n between the PEM lines.
# The .p8 is downloadable exactly once from Apple and is never committed.
APNS_KEY_P8=/root/secrets/AuthKey_XXXXXXXXXX.p8
APNS_KEY_ID=              # 10 chars, from the key's filename / Apple's list
APNS_TEAM_ID=             # 10 chars, top-right of the Apple Developer portal
APNS_BUNDLE_ID=           # the app's bundle id; the worker appends
                          # .push-type.liveactivity for the apns-topic header

# Which APNs host a token registered as "auto" is sent to. Devices normally
# declare their own environment at registration; this is the fallback.
# sandbox = builds from Xcode, production = TestFlight and the App Store.
APNS_DEFAULT_ENV=sandbox

# Set to "on" to expose POST /api/live-activity/test-push, which pushes an
# arbitrary content-state to one token. Useful while wiring up a device.
# Leave unset in production.
ENABLE_LIVE_ACTIVITY_TEST_PUSH=
